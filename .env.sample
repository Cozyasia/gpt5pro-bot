# ===================== TELEGRAM =====================
BOT_TOKEN=
# Альтернатива, если в Render уже используется другое имя переменной:
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=gpt5pro_bot
PUBLIC_URL=https://gpt5pro-bot.onrender.com
USE_WEBHOOK=1
WEBHOOK_PATH=/tg
TELEGRAM_WEBHOOK_SECRET=

# ===================== WEBAPP / MINI APP =====================
# Укажи фактический URL мини-приложения/статического сайта.
WEBAPP_URL=https://gpt5pro-webapp.onrender.com/premium.html
TARIFF_URL=https://gpt5pro-webapp.onrender.com/premium.html

# ===================== OPENAI / TEXT / IMAGES / TTS =====================
# Для обычного GPT-чата можно использовать OpenRouter или OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
TEXT_PROVIDER=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Neuro-Bot GPT-5

# Картинки / TTS
OPENAI_IMAGE_KEY=
OPENAI_TTS_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ===================== LIVE INTERNET / SEARCH =====================
# Чтобы бот отвечал на актуальные вопросы: курс BTC, новости, законы, погода, релизы.
LIVE_SEARCH_ENABLED=1
LIVE_SEARCH_TIMEOUT_S=18

# Основной внешний поиск. Рекомендуется заполнить, если OPENAI_API_KEY идёт через OpenRouter.
TAVILY_API_KEY=

# Fallback через OpenAI Responses API + web search.
# Работает только с официальным OPENAI_API_KEY, не с OpenRouter sk-or-*.
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini-search-preview

# Криптовалюты: быстрый публичный API без ключа.
CRYPTO_RATE_ENABLED=1
BINANCE_MARKET_BASE=https://api.binance.com

# ===================== STT / VOICE =====================
DEEPGRAM_API_KEY=
OPENAI_STT_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ===================== COMET API: RUNWAY / SORA / KLING =====================
COMET_API_KEY=
COMET_BASE_URL=https://api.cometapi.com

# Runway — только image→video / оживление фото, не text→video.
RUNWAY_USE_COMET=1
RUNWAY_MODEL=gen3a_turbo
RUNWAY_RATIO=720:1280
RUNWAY_DURATION_S=8
RUNWAY_COMET_CREATE_PATH=/runwayml/v1/image_to_video
RUNWAY_COMET_STATUS_PATH=/runwayml/v1/tasks/{id}

# Sora 2
SORA_ENABLED=1
SORA_MODEL=sora-2
SORA_CREATE_PATH=/v1/videos
SORA_STATUS_PATH=/v1/videos/{id}
SORA_UNIT_COST_USD=0.15
SORA_PRO_UNIT_COST_USD=0.30

# Kling
KLING_ENABLED=1
KLING_MODEL=kling-v1-6
KLING_CREATE_PATH=/kling/v1/videos/image2video
KLING_STATUS_PATH=/kling/v1/videos/image2video/{id}
KLING_TEXT_CREATE_PATH=/kling/v1/videos/text2video
KLING_TEXT_STATUS_PATH=/kling/v1/videos/text2video/{id}
KLING_UNIT_COST_USD=0.80

# Luma временно скрыта/не используется. Когда вернёшь оплату — можно включить в код и заполнить ключ.
LUMA_API_KEY=

# ===================== PAYMENTS / LIMITS / DB =====================
YOOKASSA_PROVIDER_TOKEN=
CRYPTO_PAY_API_TOKEN=
OWNER_ID=
UNLIM_USER_IDS=
UNLIM_USERNAMES=gpt5pro_support
DB_PATH=/data/subs.db
USD_RUB=100
