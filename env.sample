# Neyro-Bot GPT 5 Studio v84
# Это пример. Секреты не публикуйте и не коммитьте.

# ── Telegram / Render ──
BOT_TOKEN=
BOT_USERNAME=
PUBLIC_URL=https://YOUR-BOT.onrender.com
WEBAPP_URL=https://YOUR-WEBAPP.onrender.com/premium.html?v=84
TARIFF_URL=https://YOUR-WEBAPP.onrender.com/premium.html?v=84
USE_WEBHOOK=1
WEBHOOK_PATH=/tg
TELEGRAM_WEBHOOK_SECRET=
DB_PATH=/data/subs.db

# ── Text GPT / OpenRouter ──
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
TEXT_PROVIDER=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Neyro-Bot GPT 5 Studio

# ── CometAPI / video / Midjourney / Suno ──
COMET_API_KEY=
COMET_BASE_URL=https://api.cometapi.com
TEXT_VIDEO_ALLOW_RUNWAY=1
SORA_MODEL=sora-2
SORA_CREATE_PATH=/v1/videos
SORA_STATUS_PATH=/v1/videos/{id}
KLING_MODEL=kling-v1-6
KLING_TEXT_CREATE_PATH=/kling/v1/videos/text2video
KLING_TEXT_STATUS_PATH=/kling/v1/videos/text2video/{id}
RUNWAY_USE_COMET=1
RUNWAY_COMET_CREATE_PATH=/runwayml/v1/image_to_video
RUNWAY_COMET_STATUS_PATH=/runwayml/v1/tasks/{id}
RUNWAY_API_VERSION=2024-11-06
RUNWAY_API_KEY=

MIDJOURNEY_ENABLED=1
MIDJOURNEY_MODE=fast
MIDJOURNEY_CREATE_PATH=/mj-fast/mj/submit/imagine
MIDJOURNEY_STATUS_PATH=/mj/task/{id}/fetch
MIDJOURNEY_TIMEOUT_S=600
MIDJOURNEY_POLL_DELAY_S=5
MIDJOURNEY_UNIT_COST_USD=0.134
MIDJOURNEY_DEFAULT_VERSION=7

SUNO_ENABLED=1
SUNO_API_KEY=
SUNO_BASE_URL=https://api.cometapi.com
SUNO_MODEL=chirp-bluejay

# ── Retail credits ──
# Пользователь видит только кредиты. 1 кредит = 1 ₽.
USD_RUB=100
CREDIT_RUB_VALUE=1
GENERATION_PRICE_MULTIPLIER=2.0
GENERATION_FIXED_OVERHEAD_CREDITS=0
GENERATION_PRICE_ROUND_TO=5
CREDIT_RESERVATION_TTL_S=10800

# Внутренняя себестоимость провайдера. Розничная цена рассчитывается автоматически.
SORA_COST_PER_SECOND_USD=0.08
SORA_PRO_COST_PER_SECOND_USD=0.12
KLING_5S_COST_USD=0.23
RUNWAY_5S_COST_USD=0.32
IMG_COST_USD=0.08
SUNO_COST_USD=0.20
FACESWAP_FAST_COST_USD=0.03
FACESWAP_PREMIUM_COST_USD=0.12

START_INCLUDED_CREDITS=200
PRO_INCLUDED_CREDITS=1200
ULT_INCLUDED_CREDITS=3500
CREDIT_PACK_SMALL_CREDITS=1000
CREDIT_PACK_SMALL_RUB=990
CREDIT_PACK_MID_CREDITS=3000
CREDIT_PACK_MID_RUB=2490
CREDIT_PACK_BIG_CREDITS=7000
CREDIT_PACK_BIG_RUB=4990

# ── Persistent virtual chats ──
CHAT_MEMORY_ENABLED=1
CHAT_MEMORY_MAX_MESSAGES=16
CHAT_MEMORY_MAX_CHARS=6000
CHAT_MEMORY_TTL_DAYS=0
CHAT_MAX_CONVERSATIONS=4
CHAT_HISTORY_PAGE_SIZE=8

# ── Payments ──
YOO_DIRECT_ENABLED=1
YOO_DEFAULT_METHOD=sbp
YOO_SBP_ENABLED=1
YOO_SBERPAY_ENABLED=1
YOO_TPAY_ENABLED=1
YOO_MIRPAY_ENABLED=1
YOO_CARD_ENABLED=1
YOO_PAYMENT_RETURN_URL=https://YOUR-BOT.onrender.com/payment_return
YOO_PAYMENT_POLL_SECONDS=900
YOO_PAYMENT_POLL_INTERVAL_S=5
YOO_DEBUG_PAY_ERRORS=1
CRYPTO_PAY_API_TOKEN=
CRYPTO_ASSET=USDT

# Recommended Render Secret File: yookassa.env
# YK_ID=YOUR_SHOP_ID
# YK_KEY=YOUR_SECRET_KEY
# YK_RECEIPT_EMAIL=your-email@example.com
# YK_VAT_CODE=1

# ── Images / audio / search ──
OPENAI_IMAGE_KEY=
OPENAI_TTS_KEY=
OPENAI_STT_KEY=
DEEPGRAM_API_KEY=
TAVILY_API_KEY=
LIVE_SEARCH_ENABLED=1
# v84: точная дата для слов «сегодня/сейчас» и фильтр свежих новостей.
APP_TIMEZONE=Europe/Moscow
LIVE_SEARCH_DATE_GUARD=1
LIVE_SEARCH_TODAY_TIME_RANGE=day
LIVE_SEARCH_RECENT_TIME_RANGE=week
LIVE_SEARCH_NEWS_MAX_RESULTS=8

# Other current project providers
PHOTOROOM_API_KEY=
PIAPI_API_KEY=
SEGMIND_API_KEY=

# ── Presentation / Catalog Studio v85 ──
# Persistent project assets are stored next to the SQLite DB on the Render disk.
PRESENTATION_DATA_DIR=/data/presentation_studio
# Maximum uploaded images in one project, including images from ZIP archives.
PRESENTATION_MAX_UPLOADS=60
# Safety limit for AI-generated slide visuals per project.
PRESENTATION_MAX_GENERATED_IMAGES=8
# Internal provider cost before GENERATION_PRICE_MULTIPLIER; charged only after both PDF and PPTX are sent.
PRESENTATION_RENDER_COST_USD=0.20
# Auto chooses Midjourney for premium/lifestyle scenes and OpenAI/Comet Images for precise product visuals.
PRESENTATION_IMAGE_ENGINE_AUTO=1
