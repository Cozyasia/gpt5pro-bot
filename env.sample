# ============================================================
# GPT5PRO BOT — ENV SAMPLE v49-comet-bria-bg-upscale
# Схема: всё через CometAPI.
# Фото-функции:
# - удалить фон: bria/remove-background -> прозрачный PNG
# - заменить фон: bria/remove-background -> alpha PNG, затем локальная композиция Pillow
# - улучшить разрешение: bria/increase-resolution -> 2x / 4x с preserve_alpha
# ============================================================

# ===================== TELEGRAM =====================
BOT_TOKEN=
# Альтернатива, если в Render уже используется другое имя переменной:
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=gpt5pro_bot
PUBLIC_URL=https://gpt5pro-bot.onrender.com
USE_WEBHOOK=1
WEBHOOK_PATH=/tg
TELEGRAM_WEBHOOK_SECRET=

# ===================== WEBAPP / MINI APP =====================
WEBAPP_URL=https://gpt5pro-webapp.onrender.com/premium.html
TARIFF_URL=https://gpt5pro-webapp.onrender.com/premium.html

# ===================== OPENAI / TEXT / IMAGES / TTS =====================
# Для обычного GPT-чата можно использовать OpenRouter или OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
TEXT_PROVIDER=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Neuro-Bot GPT-5

# Картинки / ретушь / TTS. Для image edit нужен официальный OpenAI key или совместимый proxy.
OPENAI_IMAGE_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_KEY=
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
TTS_MAX_CHARS=1000

# ===================== LIVE INTERNET / SEARCH =====================
LIVE_SEARCH_ENABLED=1
LIVE_SEARCH_TIMEOUT_S=18
TAVILY_API_KEY=
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini-search-preview
CRYPTO_RATE_ENABLED=1
BINANCE_MARKET_BASE=https://api.binance.com

# ===================== STT / VOICE =====================
DEEPGRAM_API_KEY=
OPENAI_STT_KEY=
OPENAI_STT_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ===================== COMET API CORE =====================
COMET_API_KEY=
COMET_BASE_URL=https://api.cometapi.com
COMET_OPENAI_BASE_URL=https://api.cometapi.com/v1

# ===================== COMET BRIA: BACKGROUND REMOVE / REPLACE =====================
# ВАЖНО v49:
# - НЕ используем /bria/image/edit/remove_background, потому что на Comet он давал invalid relay mode.
# - Telegram file URL с токеном бота не отправляем наружу: COMET_BG_USE_TELEGRAM_URL=0.
# - Вход уходит как data:image/...;base64.
BG_PROVIDER=comet
COMET_BG_MODEL=bria/remove-background
COMET_BG_REPLICATE_MODEL=bria/remove-background
COMET_BG_REPLICATE_PATH=/replicate/v1/models/bria/remove-background/predictions
COMET_BG_REMOVE_PATH=/replicate/v1/models/bria/remove-background/predictions
COMET_BG_REMOVE_PATHS=/replicate/v1/models/bria/remove-background/predictions,/v1/responses,/bria/image/edit/remove-background
COMET_BG_STATUS_PATH=/replicate/v1/predictions/{id}
COMET_BG_STATUS_PATHS=/replicate/v1/predictions/{id},/v1/responses/{id},/bria/{id}
COMET_BG_TIMEOUT_S=180
COMET_BG_POLL_DELAY_S=3
COMET_BG_MAX_WAIT_S=180
COMET_BG_USE_TELEGRAM_URL=0
# На время тестов лучше 1, после стабильного деплоя можно 0.
COMET_BG_DEBUG_TO_CHAT=1
# Второй ключ не нужен, но код поддерживает отдельный Comet-key только для Bria, если понадобится.
COMET_BRIA_API_KEY=

# Local/legacy fallback выключен: работаем через Comet.
LOCAL_REMBG_ENABLED=0
BRIA_ALLOW_LOCAL_FALLBACK=0

# ===================== COMET BRIA: INCREASE RESOLUTION / UPSCALE =====================
# Новая функция v49: кнопка «Улучшить 2x/4x».
# Модель сохраняет исходное содержание и поддерживает preserve_alpha для PNG с прозрачностью.
COMET_UPSCALE_MODEL=bria/increase-resolution
COMET_UPSCALE_REPLICATE_MODEL=bria/increase-resolution
COMET_UPSCALE_REPLICATE_PATH=/replicate/v1/models/bria/increase-resolution/predictions
COMET_UPSCALE_PATHS=/replicate/v1/models/bria/increase-resolution/predictions,/bria/image/edit/increase-resolution,/v1/responses
COMET_UPSCALE_STATUS_PATHS=/replicate/v1/predictions/{id},/bria/{id},/v1/responses/{id}
COMET_UPSCALE_DEFAULT_FACTOR=2
COMET_UPSCALE_TIMEOUT_S=240
COMET_UPSCALE_POLL_DELAY_S=3
COMET_UPSCALE_MAX_WAIT_S=240
COMET_UPSCALE_USE_TELEGRAM_URL=0
# На время тестов лучше 1, после стабильного деплоя можно 0.
COMET_UPSCALE_DEBUG_TO_CHAT=1

# ===================== RUNWAY / SORA / KLING THROUGH COMET =====================
# Runway оставлен только image→video / оживление фото, не text→video.
RUNWAY_ENABLED=1
RUNWAY_USE_COMET=1
RUNWAY_MODEL=gen3a_turbo
RUNWAY_RATIO=720:1280
RUNWAY_DURATION_S=5
RUNWAY_COMET_CREATE_PATH=/runwayml/v1/image_to_video
RUNWAY_COMET_STATUS_PATH=/runwayml/v1/tasks/{id}
RUNWAY_UNIT_COST_USD=7.0
RUNWAY_MAX_WAIT_S=1200
VIDEO_POLL_DELAY_S=6.0

# Sora 2. По умолчанию выключен, можно включить после проверки канала Comet.
SORA_ENABLED=0
SORA_MODEL=sora-2
SORA_CREATE_PATH=/v1/videos
SORA_STATUS_PATH=/v1/videos/{id}
SORA_UNIT_COST_USD=0.15
SORA_PRO_UNIT_COST_USD=0.30

# Kling
KLING_ENABLED=1
KLING_MODEL=kling-v1-6
KLING_CREATE_PATH=/kling/v1/videos/image2video
KLING_STATUS_PATH=/kling/v1/videos/image2video/{id}
KLING_TEXT_CREATE_PATH=/kling/v1/videos/text2video
KLING_TEXT_STATUS_PATH=/kling/v1/videos/text2video/{id}
KLING_UNIT_COST_USD=0.80
KLING_MULTI_CREATE_PATH=/kling/v1/videos/multi-image2video
KLING_MULTI_STATUS_PATH=/kling/v1/videos/multi-image2video/{id}
KLING_AVATAR_CREATE_PATH=/kling/v1/videos/avatar/image2video
KLING_LIPSYNC_IDENTIFY_PATH=/kling/v1/videos/identify-face

# ===================== CREATIVE ROUTER / AI REELS STUDIO =====================
AUTO_ENGINE_ENABLED=1
AUTO_ENGINE_DEFAULT=auto
REELS_STUDIO_ENABLED=1
REELS_DEFAULT_ASPECT=9:16
REELS_DEFAULT_DURATION_S=20
REELS_SCENE_DURATION_S=5
REELS_MAX_PHOTOS=12
REELS_ALBUM_SETTLE_S=2.2
REELS_AUTO_POST=1
REELS_AUTO_COVER=1
REELS_AUTO_SUBTITLES=1
REELS_AUTO_MUSIC=0
BRAND_KIT_ENABLED=1

# ===================== ADDITIONAL COMET VIDEO ENGINES =====================
SEEDANCE_ENABLED=1
SEEDANCE_MODEL=doubao-seedance-2-0-fast
SEEDANCE_CREATE_PATH=/v1/videos
SEEDANCE_STATUS_PATH=/v1/videos/{id}
SEEDANCE_UNIT_COST_USD=0.25
SEEDANCE_AUTO_FIRST=0

VEO_ENABLED=0
VEO_MODEL=veo3.1_fast
VEO_CREATE_PATH=/v1/videos
VEO_STATUS_PATH=/v1/videos/{id}
VEO_UNIT_COST_USD=1.00

HAILUO_ENABLED=0
HAILUO_MODEL=hailuo-2.3
HAILUO_CREATE_PATH=/v1/videos
HAILUO_STATUS_PATH=/v1/videos/{id}
HAILUO_UNIT_COST_USD=0.25

VIDU_ENABLED=0
VIDU_MODEL=vidu-q3
VIDU_CREATE_PATH=/v1/videos
VIDU_STATUS_PATH=/v1/videos/{id}
VIDU_UNIT_COST_USD=0.25

GROK_VIDEO_ENABLED=0
GROK_VIDEO_MODEL=grok-imagine-video
GROK_VIDEO_CREATE_PATH=/v1/videos
GROK_VIDEO_STATUS_PATH=/v1/videos/{id}
GROK_VIDEO_UNIT_COST_USD=0.10

# Luma временно не показывается и не используется.
LUMA_ENABLED=0
LUMA_API_KEY=
LUMA_MAX_WAIT_S=900

# ===================== AUDIO / SUBTITLES / MUSIC VIA COMET =====================
COMET_TTS_MODEL=tts-1
COMET_TTS_VOICE=alloy
COMET_TTS_PATH=/v1/audio/speech
COMET_TRANSCRIBE_MODEL=whisper-1
COMET_TRANSCRIBE_PATH=/v1/audio/transcriptions
SUNO_ENABLED=0
SUNO_MODEL_VERSION=chirp-auk
SUNO_CREATE_PATH=/suno/submit/music
SUNO_FETCH_PATH=/suno/fetch/{task_id}
SUNO_UNIT_COST_USD=0.15

# ===================== PAYMENTS / LIMITS / DB =====================
YOOKASSA_PROVIDER_TOKEN=
YOOKASSA_CURRENCY=RUB
CRYPTO_PAY_API_TOKEN=
CRYPTO_ASSET=USDT
PROVIDER_TOKEN_YOOKASSA=
DB_PATH=/data/subs.db
OWNER_ID=
UNLIM_USER_IDS=
UNLIM_USERNAMES=gpt5pro_support
FORCE_OWNER_UNLIM=1
USD_RUB=100
MIN_RUB_FOR_INVOICE=100

# Тарифы / цены
PRICE_START_RUB=499
PRICE_PRO_RUB=1299
PRICE_ULT_RUB=2990
PRICE_START_USD=4.99
PRICE_PRO_USD=12.99
PRICE_ULT_USD=29.90

# Наценка для разовых операций / кошелька
ONEOFF_MARKUP_DEFAULT=1.0
ONEOFF_MARKUP_RUNWAY=0.5
IMG_COST_USD=0.05
