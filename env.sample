# ===================== TELEGRAM =====================
BOT_TOKEN=
# Альтернатива, если в Render уже используется другое имя переменной:
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=gpt5pro_bot
PUBLIC_URL=https://gpt5pro-bot.onrender.com
USE_WEBHOOK=1
WEBHOOK_PATH=/tg
TELEGRAM_WEBHOOK_SECRET=

# ===================== WEBAPP / MINI APP =====================
# Укажи фактический URL мини-приложения/статического сайта.
WEBAPP_URL=https://gpt5pro-webapp.onrender.com/premium.html
TARIFF_URL=https://gpt5pro-webapp.onrender.com/premium.html

# ===================== OPENAI / TEXT / IMAGES / TTS =====================
# Для обычного GPT-чата можно использовать OpenRouter или OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
TEXT_PROVIDER=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Neuro-Bot GPT-5

# Картинки / TTS
OPENAI_IMAGE_KEY=
OPENAI_TTS_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ===================== LIVE INTERNET / SEARCH =====================
# Чтобы бот отвечал на актуальные вопросы: курс BTC, новости, законы, погода, релизы.
LIVE_SEARCH_ENABLED=1
LIVE_SEARCH_TIMEOUT_S=18

# Основной внешний поиск. Рекомендуется заполнить, если OPENAI_API_KEY идёт через OpenRouter.
TAVILY_API_KEY=

# Fallback через OpenAI Responses API + web search.
# Работает только с официальным OPENAI_API_KEY, не с OpenRouter sk-or-*.
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini-search-preview

# Криптовалюты: быстрый публичный API без ключа.
CRYPTO_RATE_ENABLED=1
BINANCE_MARKET_BASE=https://api.binance.com

# ===================== STT / VOICE =====================
DEEPGRAM_API_KEY=
OPENAI_STT_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ===================== COMET API: RUNWAY / SORA / KLING =====================
COMET_API_KEY=
COMET_BASE_URL=https://api.cometapi.com

# Runway — только image→video / оживление фото, не text→video.
RUNWAY_USE_COMET=1
RUNWAY_MODEL=gen3a_turbo
RUNWAY_TASK_NOT_EXIST_FALLBACK_S=90
RUNWAY_AUTO_FALLBACK_KLING=1
RUNWAY_RATIO=720:1280
RUNWAY_DURATION_S=8
RUNWAY_COMET_CREATE_PATH=/runwayml/v1/image_to_video
RUNWAY_COMET_STATUS_PATH=/runwayml/v1/tasks/{id}

# Sora 2
SORA_ENABLED=1
SORA_MODEL=sora-2
SORA_CREATE_PATH=/v1/videos
SORA_STATUS_PATH=/v1/videos/{id}
SORA_UNIT_COST_USD=0.15
SORA_PRO_UNIT_COST_USD=0.30

# Kling
KLING_ENABLED=1
KLING_MODEL=kling-v1-6
KLING_CREATE_PATH=/kling/v1/videos/image2video
KLING_STATUS_PATH=/kling/v1/videos/image2video/{id}
KLING_TEXT_CREATE_PATH=/kling/v1/videos/text2video
KLING_TEXT_STATUS_PATH=/kling/v1/videos/text2video/{id}
KLING_UNIT_COST_USD=0.80

# ===================== BACKGROUND REMOVE / REPLACE =====================
# Production provider: Photoroom Remove Background API
BG_PROVIDER=photoroom-api-only
BG_DISABLE_LOCAL_REMBG=1
LOCAL_REMBG_ENABLED=0
BG_FORCE_LOCAL_REMBG=0
BG_LOCAL_FIRST=0
LOCAL_REMBG_SUBPROCESS=0
BG_ACTION_TIMEOUT_S=90

# Photoroom API key — вставить в Render Environment, не в код.
PHOTOROOM_API_KEY=
PHOTOROOM_BASE_URL=https://sdk.photoroom.com
PHOTOROOM_REMOVE_PATH=/v1/segment
# AI замена фона по тексту / селфи-режим
PHOTOROOM_EDIT_ENABLED=1
PHOTOROOM_EDIT_BASE_URL=https://image-api.photoroom.com
PHOTOROOM_EDIT_PATH=/v2/edit
PHOTOROOM_EDIT_TIMEOUT_S=95
PHOTOROOM_EDIT_EXPAND_PROMPT_MODE=ai.never
PHOTOROOM_EDIT_NEGATIVE_PROMPT=phone, smartphone, phone edge, mirror, selfie stick, frame, window frame, black bar, vertical bar, pole, reflection, extra object, extra person, duplicate person, extra hands, text, watermark, logo, illustration, cartoon, painting, anime, CGI, 3d render, surreal background, distorted face, distorted horizon
PHOTOROOM_FORMAT=png
PHOTOROOM_CHANNELS=rgba
PHOTOROOM_SIZE=hd
PHOTOROOM_CROP=false
PHOTOROOM_DESPILL=false
PHOTOROOM_TIMEOUT_S=70

# Optional legacy remove.bg fallback. Не нужен, если используем только Photoroom.
REMOVE_BG_API_KEY=
REMOVE_BG_SIZE=auto
REMOVE_BG_FORMAT=png
REMOVE_BG_TIMEOUT_S=60

# Optional fallbacks, currently disabled unless BG_PROVIDER=multi/auto.
BG_COMET_MODEL=bria/remove-background
BG_COMET_REMOVE_PATH=/v1/images/edits
BG_REMOVE_TIMEOUT_S=90
BRIA_API_KEY=
BRIA_BASE_URL=https://engine.prod.bria-api.com
BRIA_REMOVE_PATH=/v1/background/remove
BRIA_ALLOW_LOCAL_FALLBACK=0

# Local rembg disabled on Render Starter: CPU timeout/large model problems.
REMBG_MODEL=u2netp
REMBG_MODEL_FALLBACKS=u2netp
REMBG_MAX_SIDE=1600
U2NET_HOME=/tmp/.u2net
XDG_CACHE_HOME=/tmp/.cache
LOCAL_REMBG_TIMEOUT_S=180
OMP_NUM_THREADS=1

# Luma временно скрыта/не используется. Когда вернёшь оплату — можно включить в код и заполнить ключ.
LUMA_API_KEY=


# ===================== FACE SWAP / ЗАМЕНА ЛИЦА =====================
# Рекомендация: начать с PiAPI как fast/cheap, Segmind подключить как premium/fallback.
FACESWAP_ENABLED=1
FACESWAP_PROVIDER=piapi
FACESWAP_FALLBACK_PROVIDER=segmind
FACESWAP_FAST_COST_USD=0.03
FACESWAP_PREMIUM_COST_USD=0.12
FACESWAP_TIMEOUT_S=180
FACESWAP_POLL_DELAY_S=2.5
FACESWAP_INPUT_MAX_SIDE=1600
FACESWAP_OUTPUT_MAX_SIDE=1600
FACESWAP_RESULT_AS_DOCUMENT=0
# Если провайдер не принимает чистый base64, поставь 1 — будет data:image/jpeg;base64,...
FACESWAP_IMAGE_DATA_URL=0

# PiAPI FaceSwap
PIAPI_API_KEY=
PIAPI_BASE_URL=https://api.piapi.ai
PIAPI_FACE_CREATE_PATH=/api/v1/task
PIAPI_FACE_STATUS_PATH=/api/v1/task/{task_id}
PIAPI_FACE_MODEL=Qubico/image-toolkit
PIAPI_FACE_TASK_TYPE=face-swap

# Segmind FaceSwap fallback/premium
SEGMIND_API_KEY=
SEGMIND_BASE_URL=https://api.segmind.com
SEGMIND_FACESWAP_MODEL_FAST=faceswap-v2
SEGMIND_FACESWAP_MODEL_PREMIUM=faceswap-v4
SEGMIND_FACE_RESTORE=codeformer-v0.1.0.pth
SEGMIND_FACE_SWAP_TYPE=head
SEGMIND_FACE_STYLE_TYPE=normal

# ===================== PAYMENTS / LIMITS / DB =====================
YOOKASSA_PROVIDER_TOKEN=
CRYPTO_PAY_API_TOKEN=
OWNER_ID=
UNLIM_USER_IDS=
UNLIM_USERNAMES=gpt5pro_support
DB_PATH=/data/subs.db
USD_RUB=100

VIDEO_RESULT_SEND_AS_DOCUMENT=1
VIDEO_RESULT_DEDUPE_TTL_S=900

SORA_AUTO_FALLBACK_KLING=1
BG_LOCAL_FIRST=1
REMBG_MAX_SIDE=1600
BG_FORCE_LOCAL_REMBG=1

LOCAL_REMBG_SUBPROCESS=1
BG_ACTION_TIMEOUT_S=180

# Photoroom size/time optimization and real photo replacement backgrounds
PHOTOROOM_INPUT_MAX_SIDE=1400
BG_OUTPUT_MAX_SIDE=1400
BG_REALISTIC_BACKGROUNDS=1
BG_BACKGROUND_TIMEOUT_S=12
BG_CACHE_DIR=/tmp/bg_cache
